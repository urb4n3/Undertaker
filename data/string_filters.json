{
  "categories": [
    {
      "name": "c2",
      "priority": 1,
      "patterns": [
        "https?://",
        "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
        "(?i)\\b(?:[a-z0-9-]+\\.)+(?:com|net|org|ru|cn|tk|xyz|top|cc|pw)\\b",
        "(?i)user-?agent",
        "(?i)mozilla/",
        "(?i)POST\\s+/",
        "(?i)GET\\s+/"
      ]
    },
    {
      "name": "filesystem",
      "priority": 3,
      "patterns": [
        "(?i)[a-z]:\\\\",
        "(?i)%[a-z]+%",
        "(?i)\\\\.\\\\pipe\\\\",
        "(?i)\\.exe|\\.dll|\\.bat|\\.cmd|\\.ps1|\\.vbs|\\.tmp"
      ]
    },
    {
      "name": "registry",
      "priority": 2,
      "patterns": [
        "(?i)HKEY_|HKLM|HKCU|HKCR",
        "(?i)SOFTWARE\\\\",
        "(?i)CurrentVersion\\\\Run",
        "(?i)CurrentVersion\\\\Explorer"
      ]
    },
    {
      "name": "crypto",
      "priority": 5,
      "patterns": [
        "(?i)\\bAES\\b|\\bRSA\\b|\\bRC4\\b|\\bDES\\b|\\bBLOWFISH\\b",
        "(?i)\\bCryptEncrypt\\b|\\bCryptDecrypt\\b|\\bCryptHash\\b|\\bCryptDeriveKey\\b",
        "(?i)\\bBCrypt\\b|\\bNCrypt\\b"
      ]
    },
    {
      "name": "mutex",
      "priority": 4,
      "patterns": [
        "(?i)Global\\\\",
        "(?i)Local\\\\",
        "(?i)\\bMutex\\b",
        "(?i)\\\\.\\\\pipe\\\\"
      ]
    },
    {
      "name": "debug",
      "priority": 6,
      "patterns": [
        "(?i)\\bdebug\\b",
        "(?i)\\berror\\b",
        "(?i)\\bfailed\\b",
        "(?i)\\bassert\\b",
        "(?i)\\btrace\\b"
      ]
    }
  ],
  "noise_filters": [
    "(?i)^\\s*$",
    "(?i)^[\\x00-\\x1f\\x7f-\\x9f]+$",
    "(?i)^[\\s.\\-_=*#@!]+$",
    "(?i)^(?:PADDING|PAD|NUL|null|none|undefined|void|false|true)$",
    "(?i)^this program cannot be run in dos mode",
    "(?i)^rich\\.",
    "(?i)^api-ms-win-",
    "(?i)^ext-ms-win-",
    "(?i)xmlns[:=]",
    "(?i)^version=\"\\d",
    "(?i)^<assembly\\s",
    "(?i)^</?[a-z]+Settings\\s*>",
    "(?i)^</?(?:assembly|dependency|dependentAssembly|security|trustInfo|application|requestedPrivileges|description)>?",
    "(?i)^<(?:assemblyIdentity|requestedExecutionLevel|ws2:)\\b",
    "(?i)^<!-- .* -->",
    "(?i)^<\\?xml\\s",
    "(?i)^@\\.(?:text|data|rdata|rsrc|reloc|didat|pdata)$",
    "(?i)^(?:kernel32|kernelbase|ntdll|user32|gdi32|advapi32|shell32|ole32|oleaut32|comctl32|comdlg32|ws2_32|crypt32|msvcrt|ucrtbase|vcruntime\\d*|msvcp\\d*|propsys|urlmon|winmm|winspool|imm32|version|secur32|bcrypt|ncrypt|setupapi|cfgmgr32|powrprof|profapi|uxtheme|dwmapi|shlwapi|rpcrt4|mscoree|clr|mscorlib)\\.dll$",
    "(?i)^[^a-zA-Z]*$",
    "(?i)^\\.\\?AV",
    "(?i)^\\.CRT\\$",
    "(?i)^\\.(?:text|data|rdata|bss|rsrc|reloc|idata|edata|tls|debug|didat|gfids|giats|gehcont|pdata|xdata|rtc|voltbl)(?:\\$.*)?$",
    "(?i)^%[\\-+0 #]?[\\d*]*\\.?[\\d*]*[hlLqjzt]*[diouxXeEfFgGaAcspnm%]",
    "(?i)^!This program cannot be run"
  ]
}
