{
  "patterns": [
    {
      "type": "domain",
      "regex": "(?i)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+(?:com|net|org|info|biz|xyz|top|ru|cn|tk|ml|ga|cf|gq|cc|pw|club|online|site|io|co|me|tv|ws|in|de|uk|br|fr|it|nl|au|jp|kr|za|gov|mil|edu)\\b",
      "description": "Domain names with common TLDs"
    },
    {
      "type": "ip",
      "regex": "\\b(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\b",
      "description": "IPv4 addresses"
    },
    {
      "type": "url",
      "regex": "(?i)https?://[^\\s\"'<>\\]\\)]{4,}",
      "description": "HTTP/HTTPS URLs"
    },
    {
      "type": "filepath",
      "regex": "(?i)(?:[a-z]:\\\\|\\\\\\\\|%[a-z]+%\\\\)[^\\s\"'<>|*?]{2,}",
      "description": "Windows file paths"
    },
    {
      "type": "registry",
      "regex": "(?i)(?:HKEY_[A-Z_]+|HKLM|HKCU|HKCR|HKU|HKCC)\\\\[^\\s\"'<>]{2,}",
      "description": "Windows registry keys"
    },
    {
      "type": "mutex",
      "regex": "(?i)(?:Global\\\\|Local\\\\)[^\\s\"'<>]{2,}",
      "description": "Named mutex/pipe objects"
    }
  ]
}
